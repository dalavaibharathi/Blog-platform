<!DOCTYPE html>
<html>
<head><title><%= post.title %></title></head>
<body style="font-family: sans-serif; max-width: 800px; margin: 40px auto; padding: 20px;">
    <a href="/dashboard" style="text-decoration:none; color:#0052cc; font-weight: bold;">&larr; Back to Dashboard</a>
    <h1><%= post.title %></h1>
    <p style="color:#666;">By: <%= post.author.username %></p>
    <hr>

    <% if (post.mediaUrl) { %>
        <div style="margin: 20px 0; text-align: center; background: #fafafa; padding: 15px; border-radius: 6px; border: 1px solid #eee;">
            <% if (post.mediaType === 'image') { %>
                <img src="<%= post.mediaUrl %>" alt="Blog Media" style="max-width: 100%; max-height: 450px; border-radius: 4px;">
            <% } else if (post.mediaType === 'video') { %>
                <video src="<%= post.mediaUrl %>" controls style="max-width: 100%; max-height: 450px; border-radius: 4px;"></video>
            <% } %>
        </div>
    <% } %>

    <p style="white-space: pre-wrap; line-height: 1.7; font-size: 1.15em; color: #222;"><%= post.content %></p>
    
    <hr style="margin-top:40px; border: 0; border-top: 1px dashed #ccc;">
    
    <h3>Comments Section</h3>
    <div style="margin-bottom: 25px;">
        <% if (comments.length === 0) { %>
            <p style="color: #888; font-style: italic;">No comments yet. Be the first to type something below!</p>
        <% } else { %>
            <% comments.forEach(comment => { %>
                <div style="background: #fdfdfd; padding: 12px; margin-bottom: 10px; border-radius: 4px; border: 1px solid #eee; border-left: 4px solid #0052cc;">
                    <strong style="color: #333;"><%= comment.author.username %></strong>
                    <p style="margin: 6px 0 0 0; color: #444;"><%= comment.content %></p>
                </div>
            <% }) %>
        <% } %>
    </div>

    <% if (userId) { %>
        <form action="/posts/<%= post._id %>/comments" method="POST" style="margin-top: 20px;">
            <textarea name="content" placeholder="Type your comment here..." required style="width:100%; padding:10px; box-sizing: border-box; min-height: 80px; border-radius: 4px; border: 1px solid #ccc;"></textarea><br>
            <button type="submit" style="background:#0052cc; color:white; border:none; padding:10px 20px; cursor:pointer; margin-top:8px; border-radius: 4px; font-weight: bold;">Submit Comment</button>
        </form>
    <% } else { %>
        <p><a href="/login">Login</a> to leave a comment.</p>
    <% } %>
</body>
</html>